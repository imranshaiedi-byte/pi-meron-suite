    "syntaxPunctuation": "muted",

    "thinkingOff": "bg",
    "thinkingMinimal": "surface",
    "thinkingLow": "elevated",
    "thinkingMedium": "muted",
    "thinkingHigh": "dim",
    "thinkingXhigh": "white",

