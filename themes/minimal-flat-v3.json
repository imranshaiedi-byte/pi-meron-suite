{
  "$schema": "https://raw.githubusercontent.com/earendil-works/pi/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
  "name": "minimal-flat-v3",
  "vars": {
    "bg": "#000000",
    "surface": "#121212",
    "elevated": "#222222",
    "highlight": "#444444",
    "muted": "#666666",
    "dim": "#bbbbbb",
    "white": "#ffffff",
    "green": "#4ade80",
    "red": "#f87171"
  },
  "colors": {
    "accent": "dim",
    "border": "elevated",
    "borderAccent": "muted",
    "borderMuted": "surface",
    "success": "green",
    "error": "red",
    "warning": "dim",
    "muted": "muted",
    "dim": "dim",
    "text": "white",
    "thinkingText": "muted",

    "selectedBg": "highlight",
    "userMessageBg": "surface",
    "userMessageText": "white",
    "customMessageBg": "surface",
    "customMessageText": "white",
    "customMessageLabel": "dim",
    "toolPendingBg": "surface",
    "toolSuccessBg": "surface",
    "toolErrorBg": "surface",
    "toolTitle": "white",
    "toolOutput": "muted",

