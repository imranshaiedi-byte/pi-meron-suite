{
  "$schema": "https://raw.githubusercontent.com/earendil-works/pi/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
  "name": "grayscale-best",
  "vars": {
    "base": "#0b0b0b",
    "surfacePending": "#121212",
    "surfaceTool": "#181818",
    "surfaceCustom": "#202020",
    "surfaceUser": "#292929",
    "surfaceError": "#313131",
    "surfaceSelected": "#383838",
    "borderSoft": "#555555",
    "border": "#777777",
    "borderStrong": "#d7d7d7",
    "fg": "#e8e8e8",
    "fgStrong": "#f4f4f4",
    "fgMax": "#ffffff",
    "fgSoft": "#c8c8c8",
    "muted": "#9a9a9a",
    "dim": "#7a7a7a",
    "faint": "#505050",
    "code": "#dedede",
    "green": "#00ff00",
    "red": "#ff0000"
  },
  "colors": {
    "accent": "fgStrong",
    "border": "border",
    "borderAccent": "borderStrong",
    "borderMuted": "borderSoft",
